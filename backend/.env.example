# Copy this file to .env.local and load it before running the app:
#   cp .env.example .env.local
#   set -a
#   source .env.local
#   set +a

# Blizzard API credentials
export BLIZZARD_CLIENT_ID=replace-me
export BLIZZARD_CLIENT_SECRET=replace-me

# Comma-separated Kotlin Region enum values:
# Europe, NorthAmerica, Korea, Taiwan
export WAE_BLIZZARD_REGIONS=Europe

# Required by AWS-related Spring beans at startup.
# Dummy values are fine for local development.
export WAE_AWS_REGION=eu-west-1
export AWS_ACCESS_KEY=local-dev-key
export AWS_SECRET_KEY=local-dev-secret

# Only needed when running with the production profile.
# export AUCTION_ENGINE_DB_USERNAME=replace-me
# export AUCTION_ENGINE_DB_PASSWORD=replace-me
