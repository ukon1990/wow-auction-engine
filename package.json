{
    "name": "wow-auction-engine",
    "private": true,
    "workspaces": [
        "frontend"
    ],
    "scripts": {
        "deploy:production:frontend": "bash scripts/deploy/local-production-frontend.sh",
        "start:backend": "cd backend && ./mvnw spring-boot:run",
        "start:frontend": "cd frontend && bun run start",
        "start:storybook": "cd frontend && bun run storybook",
        "format": "bun run format:frontend && bun run format:backend",
        "format:frontend": "cd frontend && bun run format",
        "format:backend": "cd backend && ./mvnw ktlint:format",
        "mvn": "cd backend && ./mvnw",
        "db:branch:reset": "node scripts/reset-branch-database.mjs",
        "db:branch:reset:dry-run": "node scripts/reset-branch-database.mjs --dry-run",
        "db:branch:prune": "node scripts/reset-branch-database.mjs --prune-dead",
        "db:branch:prune:dry-run": "node scripts/reset-branch-database.mjs --prune-dead --dry-run",
        "refresh:fixtures": "bun tools/refresh-fixtures.mjs",
        "generate:expansion-ranges": "node tools/generate-expansion-ranges.mjs"
    },
    "packageManager": "bun@1.3.3"
}
