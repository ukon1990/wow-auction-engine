#!/usr/bin/env bash

set -euo pipefail

if ! command -v git >/dev/null 2>&1; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$repo_root"

backend_dir="backend"

if [ -f "${backend_dir}/mvnw" ]; then
  run_maven() {
    (cd "$backend_dir" && sh "./mvnw" "$@")
  }
elif [ -f "${backend_dir}/mvnw.cmd" ]; then
  run_maven() {
    (cd "$backend_dir" && cmd.exe //c mvnw.cmd "$@")
  }
else
  echo "pre-commit: Maven wrapper not found. Expected ${backend_dir}/mvnw or ${backend_dir}/mvnw.cmd" >&2
  exit 1
fi

has_kotlin_files=0
staged_kotlin_files=()

while IFS= read -r -d '' file; do
  if [[ "$file" == "${backend_dir}/src/main/kotlin/"* && "$file" == *.kt ]]; then
    staged_kotlin_files+=("$file")
    has_kotlin_files=1
  elif [[ "$file" == "${backend_dir}/src/test/kotlin/"* && "$file" == *.kt ]]; then
    staged_kotlin_files+=("$file")
    has_kotlin_files=1
  elif [[ "$file" == "${backend_dir}/"* && "$file" == *.kts ]]; then
    staged_kotlin_files+=("$file")
    has_kotlin_files=1
  fi
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [ "$has_kotlin_files" -eq 0 ]; then
  exit 0
fi

echo "pre-commit: formatting staged Kotlin files with ktlint"
run_maven "-q" "ktlint:format"

for file in "${staged_kotlin_files[@]}"; do
  if [ -f "$file" ]; then
    git add -- "$file"
  fi
done

echo "pre-commit: lint-checking Kotlin sources with ktlint"
if ! run_maven "-q" "ktlint:check"; then
  echo "pre-commit: ktlint reported remaining violations. Review the output above and amend the staged changes." >&2
  exit 1
fi
