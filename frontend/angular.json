{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "bun",
    "analytics": "88c17136-e374-4ea4-b0f4-c0f957d643ce"
  },
  "newProjectRoot": "./frontend",
  "projects": {
    "EE": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "i18n": {
        "sourceLocale": "en",
        "locales": {
          "de": "src/locale/messages.de.xlf",
          "es": "src/locale/messages.es.xlf",
          "fr": "src/locale/messages.fr.xlf",
          "it": "src/locale/messages.it.xlf",
          "ko": "src/locale/messages.ko.xlf",
          "pt": "src/locale/messages.pt.xlf",
          "ru": "src/locale/messages.ru.xlf",
          "zh": "src/locale/messages.zh.xlf"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "server": "src/main.server.ts",
            "ssr": {
              "entry": "src/server.ts"
            },
            "outputMode": "server",
            "outputPath": "dist/The-Ethereal-Exchange",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": "/"
              }
            ],
            "styles": ["src/styles.css"],
            "security": {
              "allowedHosts": ["localhost", "127.0.0.1", "ee.jonaskf.net"]
            },
            "polyfills": ["@angular/localize/init"],
            "i18nMissingTranslation": "error"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "localize": true
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "localize": ["en"]
            },
            "de": {
              "localize": ["de"]
            },
            "es": {
              "localize": ["es"]
            },
            "fr": {
              "localize": ["fr"]
            },
            "it": {
              "localize": ["it"]
            },
            "ko": {
              "localize": ["ko"]
            },
            "pt": {
              "localize": ["pt"]
            },
            "ru": {
              "localize": ["ru"]
            },
            "zh": {
              "localize": ["zh"]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "EE:build:production"
            },
            "development": {
              "buildTarget": "EE:build:development",
              "servePath": "/en"
            },
            "de": {
              "buildTarget": "EE:build:development,de",
              "servePath": "/de"
            },
            "es": {
              "buildTarget": "EE:build:development,es",
              "servePath": "/es"
            },
            "fr": {
              "buildTarget": "EE:build:development,fr",
              "servePath": "/fr"
            },
            "it": {
              "buildTarget": "EE:build:development,it",
              "servePath": "/it"
            },
            "ko": {
              "buildTarget": "EE:build:development,ko",
              "servePath": "/ko"
            },
            "pt": {
              "buildTarget": "EE:build:development,pt",
              "servePath": "/pt"
            },
            "ru": {
              "buildTarget": "EE:build:development,ru",
              "servePath": "/ru"
            },
            "zh": {
              "buildTarget": "EE:build:development,zh",
              "servePath": "/zh"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "EE:build:development",
            "format": "xlf",
            "outputPath": "src/locale",
            "outFile": "messages.xlf"
          }
        },
        "test": {
          "builder": "@ethereal/angular-unit-test-alias:unit-test",
          "options": {
            "include": ["**/*.spec.ts", "../ethereal-ui/src/**/*.spec.ts"],
            "setupFiles": ["tools/vitest.storage-setup.ts"],
            "reporters": ["default", "github-actions"],
            "coverageReporters": [
              "text",
              "text-summary",
              "lcov",
              "html",
              ["json-summary", { "outputFile": "EE/coverage-summary.json" }]
            ],
            "coverageInclude": ["src/**/*.ts", "ethereal-ui/src/**/*.ts"],
            "coverageExclude": ["**/*.spec.ts", "src/app/api/generated/**", "src/api/generated/**"]
          }
        }
      }
    },
    "ethereal-ui": {
      "projectType": "library",
      "root": "ethereal-ui",
      "sourceRoot": "ethereal-ui/src",
      "prefix": "ee",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "ethereal-ui/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "ethereal-ui/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@ethereal/angular-unit-test-alias:unit-test",
          "options": {
            "tsConfig": "ethereal-ui/tsconfig.spec.json"
          }
        },
        "storybook": {
          "builder": "@analogjs/storybook-angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "port": 6006,
            "tsConfig": "ethereal-ui/tsconfig.storybook.json",
            "styles": ["src/styles.css"],
            "compodoc": false,
            "experimentalZoneless": true
          }
        },
        "build-storybook": {
          "builder": "@analogjs/storybook-angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "outputDir": "storybook-static",
            "tsConfig": "ethereal-ui/tsconfig.storybook.json",
            "styles": ["src/styles.css"],
            "compodoc": false,
            "experimentalZoneless": true
          }
        }
      }
    }
  }
}
