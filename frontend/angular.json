{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "bun",
    "analytics": "88c17136-e374-4ea4-b0f4-c0f957d643ce"
  },
  "newProjectRoot": "./frontend",
  "projects": {
    "EE": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "server": "src/main.server.ts",
            "ssr": {
              "entry": "src/server.ts"
            },
            "outputMode": "server",
            "outputPath": "dist/The-Ethereal-Exchange",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": "/"
              }
            ],
            "styles": ["src/styles.css"],
            "security": {
              "allowedHosts": ["localhost", "127.0.0.1"]
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "proxyConfig": "proxy.conf.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "EE:build:production"
            },
            "development": {
              "buildTarget": "EE:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@ethereal/angular-unit-test-alias:unit-test",
          "options": {
            "include": ["**/*.spec.ts", "../ethereal-ui/src/**/*.spec.ts"]
          }
        }
      }
    },
    "ethereal-ui": {
      "projectType": "library",
      "root": "ethereal-ui",
      "sourceRoot": "ethereal-ui/src",
      "prefix": "ee",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "ethereal-ui/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "ethereal-ui/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@ethereal/angular-unit-test-alias:unit-test",
          "options": {
            "tsConfig": "ethereal-ui/tsconfig.spec.json"
          }
        },
        "storybook": {
          "builder": "@analogjs/storybook-angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "port": 6006,
            "tsConfig": "ethereal-ui/tsconfig.storybook.json",
            "styles": ["src/styles.css"],
            "compodoc": false,
            "experimentalZoneless": true
          }
        },
        "build-storybook": {
          "builder": "@analogjs/storybook-angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "outputDir": "storybook-static",
            "tsConfig": "ethereal-ui/tsconfig.storybook.json",
            "styles": ["src/styles.css"],
            "compodoc": false,
            "experimentalZoneless": true
          }
        }
      }
    }
  }
}
