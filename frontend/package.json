{
  "name": "the-ethereal-exchange",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "generate:api": "openapi-generator-cli generate -g typescript-angular -i ../openapi/openapi.yml -o src/app/api/generated --additional-properties=ngVersion=21.2.0,providedInRoot=true,serviceSuffix=ApiService",
    "prebuild": "bun run generate:api",
    "build": "ng build",
    "format:check": "prettier --check .",
    "format:check:write": "prettier --check . -write",
    "lint": "eslint .",
    "storybook": "ng run ethereal-ui:storybook",
    "build-storybook": "ng run ethereal-ui:build-storybook",
    "pretest:ci": "bun run generate:api",
    "test:ci": "ng test --watch=false --progress=false",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "bun@1.3.3",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.9",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/storybook-angular": "^2.5.0",
    "@analogjs/vite-plugin-angular": "^2.5.0",
    "@analogjs/vitest-angular": "^2.5.0",
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "@ethereal/angular-unit-test-alias": "file:tools/angular-unit-test-alias",
    "@openapitools/openapi-generator-cli": "^2.25.2",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/angular": "^10.3.6",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vite": "^8.0.10",
    "vitest": "^4.0.8"
  }
}
